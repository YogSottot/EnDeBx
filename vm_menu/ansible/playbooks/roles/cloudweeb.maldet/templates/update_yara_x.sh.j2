#!/usr/bin/env bash
set -euo pipefail

release_api_url="{{ maldet_yara_x_release_api_url }}"
asset_name_pattern='{{ maldet_yara_x_asset_name_pattern }}'
install_path="{{ maldet_yara_x_binary_path }}"

release_json="$(curl -fsSL \
  -H 'Accept: application/vnd.github+json' \
  -H 'User-Agent: EnDeBx-YARA-X-Updater' \
  "${release_api_url}")"

mapfile -t release_meta < <(
  printf '%s' "${release_json}" | python3 -c '
import json
import re
import sys

data = json.load(sys.stdin)
tag = data.get("tag_name") or ""
if tag.startswith("v"):
    tag = tag[1:]

pattern = re.compile(sys.argv[1])
asset_name = ""
download_url = ""

for asset in data.get("assets", []):
    candidate = asset.get("name") or ""
    if pattern.match(candidate):
        asset_name = candidate
        download_url = asset.get("browser_download_url") or ""
        break

print(tag)
print(asset_name)
print(download_url)
' "${asset_name_pattern}"
)

latest_version="${release_meta[0]:-}"
asset_name="${release_meta[1]:-}"
download_url="${release_meta[2]:-}"

if [[ -z "${latest_version}" || -z "${asset_name}" || -z "${download_url}" ]]; then
  echo "Unable to determine latest YARA-X release asset." >&2
  exit 1
fi

current_version=""
if [[ -x "${install_path}" ]]; then
  current_version="$("${install_path}" --version 2>/dev/null | awk 'NR == 1 { print $2; exit }')"
fi

if [[ -n "${current_version}" && "${current_version}" == "${latest_version}" ]]; then
  echo "OK: YARA-X is already up to date (${current_version})."
  exit 0
fi

tmp_dir="$(mktemp -d)"
cleanup() {
  rm -rf "${tmp_dir}"
}
trap cleanup EXIT

archive_path="${tmp_dir}/${asset_name}"
curl -fsSL -o "${archive_path}" "${download_url}"
tar -xzf "${archive_path}" -C "${tmp_dir}"

yr_source_path="$(find "${tmp_dir}" -type f -name yr -print -quit)"
if [[ -z "${yr_source_path}" ]]; then
  echo "Downloaded YARA-X archive does not contain yr binary." >&2
  exit 1
fi

install -o root -g root -m 0755 "${yr_source_path}" "${install_path}"
echo "UPDATED: Installed YARA-X ${latest_version}."
