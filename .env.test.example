# shellcheck shell=bash
BS_PATH_USER_HOME_PREFIX="/var/www"
BS_PATH_USER_HOME="bitrix"
BS_PATH_SITES="$BS_PATH_USER_HOME_PREFIX/$BS_PATH_USER_HOME"
BS_DEFAULT_SITE_NAME="default"
BS_PATH_DEFAULT_SITE="$BS_PATH_SITES/$BS_DEFAULT_SITE_NAME"
BS_USER_SERVER_SITES="bitrix"
BS_GROUP_USER_SERVER_SITES="bitrix"
BS_DEFAULT_USER_SERVER_SITES="bitrix"
BS_SITE_LINKS_RESOURCES=("bitrix" "upload" "images")
BS_SERVER_TIMEZONE="Europe/Moscow"
BX_DOWNLOAD_BITRIXSETUP="N"
BS_INSTALL_BASH_ALIASES=Y
BS_OPTIMIZE_SYSCTL=Y

# Устанавливать push-сервер
BS_INSTALL_PUSH_SERVER=Y
  # Не запускать push-server по умолчанию (Y/N).
  BS_PUSH_SERVER_STOPPED=N
  # Добавлять в /bitrix/.settings.php конфиг локального push-server (Y/N).
  BS_PUSH_SERVER_BX_SETTINGS=Y

BS_SETUP_REPOS=Y
BS_DELETE_SNAPD=Y

BS_SETUP_SWAP=Y
BS_SWAP_SIZE='1024'

BS_ADD_MENU_IN_BASH_PROFILE=N

# Base EnDeBx settings for automated test stands.
BS_ANSIBLE_DEBUG_MODE=Y
BS_EMAIL_ADMIN_FOR_NOTIFY="notify@example.com"
BS_SHOW_IP_CURRENT_SERVER_IN_MENU=false
BS_REPOSITORY_URL_FILE_VERSION=""
BS_REPOSITORY_URL=""

# Keep the first smoke scenario simple and predictable.
BS_INSTALL_DATABASE=mysql
BS_DB_FLAVOR=mariadb
BS_DB_VERSION=10.11
BS_SETUP_SECURITY=N
BS_SETUP_RKHUNTER=N
BS_SETUP_MALDET=N
BS_INSTALL_CROWDSEC=N

# Test harness values appended to /root/.env.menu and used by runner scripts.
TEST_SITE_PREFIX="portal"
TEST_SITE_EMAIL="notify@example.com"
TEST_MENU_FULL_USER="e2efull1"
TEST_MENU_DEFAULT_DOMAIN=""
TEST_MENU_ENABLE_LETS_ENCRYPT="Y"
TEST_MENU_LETS_ENCRYPT_WWW="N"
TEST_MENU_REDIRECT_TO_HTTPS="N"
TEST_MENU_FTP_USER=""
TEST_MENU_FTP_PASSWORD="E2eFtpPass1234"
TEST_MENU_FTP_DIR=""
TEST_MENU_SMTP_ACCOUNT="default"
TEST_MENU_SMTP_FROM="notify@example.com"
TEST_MENU_SMTP_HOST="smtp.example.com"
TEST_MENU_SMTP_PORT="587"
TEST_MENU_SMTP_AUTH="Y"
TEST_MENU_SMTP_LOGIN="notify@example.com"
TEST_MENU_SMTP_PASSWORD=""
TEST_MENU_SMTP_AUTH_METHOD="auto"
TEST_MENU_SMTP_TLS="Y"
TEST_MENU_SMTP_STARTTLS="Y"
TEST_MENU_SMTP_RECIPIENT="admin@example.com"
TEST_MENU_SMTP_LOG_PATH="/var/www/bitrix/msmtp_default.log"
TEST_MENU_NTLM_SITE_PATH="$BS_PATH_DEFAULT_SITE"
TEST_MENU_NTLM_SSL_LETS_ENCRYPT="N"
TEST_MENU_NTLM_NAME="TEST"
TEST_MENU_NTLM_FQDN="TEST.LOCAL"
TEST_MENU_NTLM_DPS="10.0.0.10"
TEST_MENU_NTLM_USER="Administrator"
TEST_MENU_NTLM_PASS=""
TEST_MENU_FIREWALL_PORT="54321/tcp"
TEST_MENU_FIREWALL_ZONE="public"
TEST_BITRIX_SETUP_URL="https://www.1c-bitrix.ru/download/scripts/bitrixsetup.php"
TEST_BITRIX_DIST_URL_MYSQL="https://www.1c-bitrix.ru/download/portal/bitrix24_enterprise_encode.tar.gz"
TEST_BITRIX_DIST_URL_PGSQL="https://www.1c-bitrix.ru/download/portal/bitrix24_enterprise_postgresql_encode.tar.gz"
TEST_BITRIX_CLI_INSTALL_DIR="/root/EnDeBx/tests/vendor/bitrix-cli-install"
TEST_BITRIX_ADMIN_LOGIN="admin"
TEST_BITRIX_ADMIN_PASSWORD=""
TEST_BITRIX_ADMIN_EMAIL="admin@example.com"
TEST_BITRIX_ADMIN_FIRST_NAME="Administrator"
TEST_BITRIX_ADMIN_LAST_NAME="portal"
TEST_BITRIX_LICENSE_CONTACT_FIRST_NAME=""
TEST_BITRIX_LICENSE_CONTACT_LAST_NAME=""
TEST_BITRIX_LICENSE_CONTACT_EMAIL=""
