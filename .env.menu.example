# где будут директории пользователей
BS_PATH_USER_HOME_PREFIX="/var/www"

# директория пользователя по умолчанию
BS_PATH_USER_HOME="bitrix"
BS_PATH_SITES="$BS_PATH_USER_HOME_PREFIX/$BS_PATH_USER_HOME"

# имя директории сайта по умолчанию
BS_DEFAULT_SITE_NAME="default"
BS_PATH_DEFAULT_SITE="$BS_PATH_SITES/$BS_DEFAULT_SITE_NAME"

# имя пользователя для сайта по умолчанию
BS_USER_SERVER_SITES="bitrix"
BS_GROUP_USER_SERVER_SITES="bitrix"
BS_DEFAULT_USER_SERVER_SITES="bitrix"

# на какие директории делать симлинк в сайтах типа link
BS_SITE_LINKS_RESOURCES=("local" "bitrix" "upload" "images")

# таймзона сервера и php
BS_SERVER_TIMEZONE="Europe/Moscow"

# Устанавливать bash_aliases и liquidprompt (Y/N)
BS_INSTALL_BASH_ALIASES=Y

# Применить оптимизации syctl / ulimits (Y/N)
BS_OPTIMIZE_SYSCTL=Y

# какая база данных будет установлена при первичной установке
# (mysql / pgsql)
BS_INSTALL_DATABASE=mysql

# выбор версии mysql
# (mariadb / percona)
# on Astra Linux only mariadb is supported.
#BS_DB_FLAVOR=percona
BS_DB_FLAVOR=mariadb
# percona version (5.7 / 8.0 / 8.4)
# mariadb version (5.5 / 10.11): версия 5.5 — скачивается архив. При указании другой версии — установка из репозитория дистрибутива
#BS_DB_VERSION=8.4
BS_DB_VERSION=10.11
BS_DB_CHARACTER_SET_SERVER=utf8mb4
#BS_DB_COLLATION=utf8mb4_0900_ai_ci
BS_DB_COLLATION=utf8mb4_unicode_ci

# источник установки postgresql
# (distro / official)
# distro — версия из репозитория дистрибутива
# official — указанная ниже версия из apt.postgresql.org
BS_POSTGRESQL_REPOSITORY_SOURCE=official
# версия postgresql для official-репозитория
BS_POSTGRESQL_VERSION=17
# устанавливать pgbouncer вместе с postgresql при первичной установке (Y/N)
BS_INSTALL_PGBOUNCER=N

# версия php по умолчанию при первичной установке
BX_PHP_DEFAULT_VERSION="8.4"

# Выбрать для поддержки htaccess (Y/N)
# Y — nginx + apache + php-fpm (поддерживает htaccess)
# N — nginx + php-fpm (не поддерживает htaccess, лучше производительность)
BS_HTACCESS_SUPPORT="Y"
# Логин и пароль для базовой авторизации по умолчанию. (Изменить)
BS_NGINX_BASIC_AUTH_LOGIN=user
BS_NGINX_BASIC_AUTH_PASSWORD=password

# Устанавливать push-сервер
BS_INSTALL_PUSH_SERVER=Y
# Не запускать push-server по умолчанию (Y/N).
BS_PUSH_SERVER_STOPPED=Y
# Добавлять в /bitrix/.settings.php конфиг локального push-server (Y/N).
BS_PUSH_SERVER_BX_SETTINGS=N

# Email для let's encrypt и других уведомлений (rkhunter / maldet / imunify360 / etc)
BS_EMAIL_ADMIN_FOR_NOTIFY="notify@domain.tld"

# Установить crowdsec по умолчанию
BS_INSTALL_CROWDSEC=Y
# Ключ для подключения к облачной консоли https://app.crowdsec.net (опционально)
#BS_CROWDSEC_ENROLL_KEY=
# Whitelist ip для crowdsec, измените на свои ip, через запятую (например zabbix-server и другие средства мониторинга)
BS_CROWDESC_WHITELIST_IP=3.23.109.173,3.123.246.217,5.252.32.21,13.48.50.139,13.55.250.61,15.237.38.34,18.116.210.223,18.140.111.54,18.198.159.51,18.229.108.9,34.240.122.254,46.137.35.188,46.137.97.175,46.137.123.236,46.137.125.240,46.235.53.93,51.68.148.57,51.68.148.60,51.81.71.17,51.81.71.22,51.250.14.66,51.250.25.139,52.17.35.151,54.232.199.60,69.167.178.6,69.167.178.14,79.127.208.225,79.127.208.226,79.127.235.65,79.127.235.66,79.127.235.69,89.187.182.220,89.219.34.163,93.183.85.50,93.183.85.100,94.139.247.5,95.213.198.99,108.177.136.4,109.61.92.225,109.61.92.227,138.199.36.35,138.199.36.36,143.244.45.161,143.244.45.162,143.244.45.166,148.113.0.31,148.113.0.32,152.228.247.214,158.160.117.236,176.34.103.175,176.98.235.18,176.123.176.243,185.71.64.217,185.116.195.27,185.116.195.28,185.164.148.1,185.164.149.11,185.164.149.13,185.164.149.15,185.164.149.17,185.164.149.19,185.164.149.21,185.164.149.26,185.164.149.28,185.164.149.31,185.164.149.100,185.164.150.3,185.164.150.5,185.164.150.7,185.164.150.8,185.164.150.10,188.0.150.130,188.241.216.130,193.84.88.130,195.208.184.173,217.28.226.16
# Whitelist ip-подсети для crowdsec
BS_CROWDESC_WHITELIST_CIDR=51.68.148.58/31,51.81.71.18/31,51.81.71.20/31,108.177.136.0/30,109.61.92.228/30,129.227.94.146/31,129.227.121.194/31,152.228.247.212/31,158.160.135.48/30,158.160.135.52/31,185.164.148.128/29,185.164.148.136/31,185.164.149.34/31,185.164.150.12/30,185.164.150.16/31
# устанавливаемые по умолчанию коллекции crowdsec, через запятую
BS_CROWDSEC_COLLECTION_INSTALL=crowdsecurity/mariadb,crowdsecurity/whitelist-good-actors,crowdsecurity/http-cve,crowdsecurity/iptables,fulljackz/pureftpd,crowdsecurity/appsec-generic-rules,crowdsecurity/appsec-virtual-patching
# устанавливаемые по умолчанию сценарии crowdsec, через запятую
BS_CROWDSEC_SCENARIOS_INSTALL=crowdsecurity/apache_log4j2_cve-2021-44228,crowdsecurity/http-cve-2021-42013,crowdsecurity/http-bad-user-agent,crowdsecurity/http-path-traversal-probing,crowdsecurity/http-sqli-probing,crowdsecurity/http-xss-probing,crowdsecurity/http-backdoors-attempts,ltsich/http-w00tw00t,crowdsecurity/http-open-proxy,crowdsecurity/http-admin-interface-probing,crowdsecurity/http-wordpress-scan,crowdsecurity/http-cve-probing

# Установка базовых параметров повышающих безопасность (изменить ssh-порт, выключить логин для root, отключить логин по паролю, etc) (Y/N)
BS_SETUP_SECURITY=N
# Изменить ssh-port
BS_SSH_PORT=22
# Разрешить логин для root (если поставите "no", то обязательно укажите создание альтернативного пользователя, иначе не сможете войти на сервер) ("yes"/"no"/"prohibit-password")
BS_SSH_PERMIT_ROOT_LOGIN="prohibit-password"
# Укажите альтернативного пользователя для входа на сервер с правами sudo
BS_SSH_ADMIN_USER=
# Использовать sudo без пароля для альтернативного пользователя ("true"/"false")
BS_SSH_ADMIN_USER_PASSWORDLESS_SUDO="true"
# Пароль альтернативного пользователя, если sudo должен запрашивать пароль
BS_SSH_ADMIN_USER_PASSWORD=""
# Укажите ssh-ключ для альтернативного пользователя (в одиночных кавычках. Можно несколько ключей через новую строку)
# BS_SSH_ADMIN_USER_SSH_KEY='ssh-ed25519-1234567890 root@domain.tld #имя ssh-ed25519-0987654321 root@domain.tld #другое имя'
# Включить/Отключить логин по паролю ("yes"/"no")
BS_SSH_PASSWORD_AUTHENTICATION="yes"
# Включить автоустановку обновлений безопасности ("true"/"false")
BS_AUTOUPDATE_ENABLED="true"
# Включить автоперезагрузку сервера, если это требуется после установки обновлений ("true"/"false")
BS_AUTOUPDATE_REBOOT_ENABLE="false"
# Указать время для автоперезагрузки
BS_AUTOUPDATE_REBOOT_TIME="05:00"
# Скрыть процессы других пользователей в /proc ("true"/"false")
BS_SECRITY_HIDEPID="false"
# Укажите существующего пользователя мониторинга, которому нужно сохранить доступ к /proc (например zabbix)
BS_SECRITY_HIDEPID_MONITORING_USER=""

# Установить rkhunter по умолчанию (Y/N)
BS_SETUP_RKHUNTER=N

# Установить maldet по умолчани (Y/N)
BS_SETUP_MALDET=N

# Подключить свап при установке (Y/N)
BS_SETUP_SWAP=N
# Swap size in MB
BS_SWAP_SIZE='1024'

# Добавить автоматический запуск меню при входе по ssh (Y/N)
BS_ADD_MENU_IN_BASH_PROFILE=Y

# Укажите свои дополнительные пакеты для установки при первичной установке окружения в формате "package1 package2 package3"
BX_ADDITIONAL_PACKAGES=""

# Укажите дополнительные пакеты php-расширений, они будут установлены в том числе и при изменении версии php в меню
# Указывать в формате: '["php{{ php_version }}-zmq", "php{{ php_version }}-redis"]'
BX_ADDITIONAL_PHP_EXTENSIONS=

# Перезаписать список стандартных репозиториев debian (Y/N)
BS_SETUP_REPOS=N

# Удалить и заблокировать установку snapd
BS_DELETE_SNAPD=Y
