# где будут директории пользователей
BS_PATH_USER_HOME_PREFIX="/var/www"

# директория пользователя по умолчанию
BS_PATH_USER_HOME="bitrix"
BS_PATH_SITES="$BS_PATH_USER_HOME_PREFIX/$BS_PATH_USER_HOME"

# имя директории сайта по умолчанию
BS_DEFAULT_SITE_NAME="default"
BS_PATH_DEFAULT_SITE="$BS_PATH_SITES/$BS_DEFAULT_SITE_NAME"

# имя пользователя для сайта по умолчанию
BS_USER_SERVER_SITES="bitrix"
BS_GROUP_USER_SERVER_SITES="bitrix"
BS_DEFAULT_USER_SERVER_SITES="bitrix"

# на какие директории делать симлинк в сайтах типа link
BS_SITE_LINKS_RESOURCES=("local" "bitrix" "upload" "images")

# таймзона сервера и php
BS_SERVER_TIMEZONE="Europe/Moscow"

# Устанавливать bash_aliases и liquidprompt (Y/N)
BS_INSTALL_BASH_ALIASES=Y

# Применить оптимизации syctl / ulimits (Y/N)
BS_OPTIMIZE_SYSCTL=Y

# выбор версии mysql
# (mariadb / percona)
#BS_DB_FLAVOR=percona
BS_DB_FLAVOR=mariadb
# percona version (5.7 / 8.0)
# mariadb version (5.5 / 10.11)
#BS_DB_VERSION=8.0
BS_DB_VERSION=10.11
BS_DB_CHARACTER_SET_SERVER=utf8mb4
#BS_DB_COLLATION=utf8mb4_0900_ai_ci
BS_DB_COLLATION=utf8mb4_general_ci

# версия php по умолчанию при первичной установке
BX_PHP_DEFAULT_VERSION="8.2"

# Выбрать для поддержки htaccess (Y/N)
# Y — nginx + apache + php-fpm (поддерживает htacces)
# N — nginx + php-fpm (не поддерживает htacces, лучше производительность)
BS_HTACCESS_SUPPORT="N"

# Не запускать push-server по умолчанию (Y/N).
BS_PUSH_SERVER_STOPPED=Y
# Добавлять в /bitrix/.settings.php конфиг локального push-server (Y/N).
BS_PUSH_SERVER_BX_SETTINGS=N

# Email для let's encrypt и других уведомлений (rkhunter / maldet / imunify360 / etc)
BS_EMAIL_ADMIN_FOR_NOTIFY="notify@domain.tld"

# Установить crowdsec по умолчанию
BS_INSTALL_CROWDSEC=Y
# Ключ для подключения к облачной консоли https://app.crowdsec.net (опционально)
#BS_CROWDSEC_ENROLL_KEY=
# Whitelist ip для crowdsec, измените на свои ip, через запятую (например zabbix-server и другие срества мониторинга)
BS_CROWDESC_WHITELIST_IP=185.164.148.1,185.164.149.100,95.213.198.99,158.160.117.236,217.28.226.16,51.250.14.66,185.71.64.217,51.250.25.139,18.198.159.51,5.252.32.21,18.116.210.223,3.23.109.173,193.84.88.130,54.232.199.60,176.123.176.243,188.0.150.130,46.137.125.240,46.137.97.175,46.137.123.236,69.167.178.6,176.34.103.175,46.137.35.188,46.235.53.93,94.139.247.5,34.240.122.254,52.17.35.151,195.208.184.173,109.61.92.229,109.61.92.225,109.61.92.227,109.61.92.228,109.61.92.231,109.61.92.230,152.228.247.214,152.228.247.212,152.228.247.213,108.177.136.4,108.177.136.1,108.177.136.0,108.177.136.2,108.177.136.3,185.164.150.3,185.164.150.7,185.164.150.10,185.164.150.5,185.116.195.27,185.164.149.21,185.164.149.19,185.164.149.28,185.164.149.31,185.164.149.34,185.164.150.13,185.164.150.15,185.164.148.129,185.164.148.136,185.164.149.11,185.164.149.13,185.116.195.28,185.164.148.131,185.164.150.8,185.164.149.35,185.164.148.132,185.164.149.15,185.164.149.26,185.164.148.133,185.164.148.134,185.164.148.137,185.164.150.12,185.164.148.128,185.164.149.17,185.164.148.135,185.164.148.130,185.164.150.17,185.164.150.14,185.164.150.16,185.164.149.100,185.164.148.1,79.127.235.69,79.127.235.66,79.127.208.226,79.127.208.225,79.127.235.65,129.227.94.146,129.227.121.194,129.227.121.195,129.227.94.147,138.199.36.35,138.199.36.36,158.160.135.50,158.160.135.49,158.160.135.51,158.160.135.48,158.160.135.52,158.160.135.53,143.244.45.161,143.244.45.162,143.244.45.166,51.81.71.20,51.68.148.59,51.81.71.21,51.68.148.57,51.68.148.60,51.81.71.22,51.81.71.18,51.81.71.19,51.81.71.17,51.68.148.58,89.187.182.220,89.219.34.163,148.113.0.32,148.113.0.31,93.183.85.100,93.183.85.50,13.48.50.139,13.55.250.61,15.237.38.34,18.229.108.9,18.140.111.54,3.123.246.217,176.98.235.18,95.213.198.99,69.167.178.14,188.241.216.130
# устанавливаемые по умолчанию коллекции crowdsec, через запятую
BS_CROWDSEC_COLLECTION_INSTALL=crowdsecurity/base-http-scenarios,crowdsecurity/mariadb,crowdsecurity/whitelist-good-actors,crowdsecurity/proftpd,crowdsecurity/appsec-generic-rules,crowdsecurity/appsec-virtual-patching

# Установка базовых параметров повышающих безопасность (изменить ssh-порт, выключить логин для root, отключить логин по паролю, etc) (Y/N)
BS_SETUP_SECURITY=N
# Изменить ssh-port
BS_SSH_PORT=22
# Разрешить логин для root (если поставите "no", то обязательно укажите создание альтернативного пользователя, иначе не сможете войти на сервер) ("yes"/"no"/"prohibit-password")
BS_SSH_PERMIT_ROOT_LOGIN="prohibit-password"
# Укажите альтернативного пользователя для входа на сервер с правами sudo
# BS_SSH_ADMIN_USER=
# Укажите ssh-ключ для альтернативного пользователя (в одиночных кавычках. Можно несколько ключей через новую строку)
# BS_SSH_ADMIN_USER_SSH_KEY='ssh-ed25519-1234567890 root@domain.tld #имя
ssh-ed25519-0987654321 root@domain.tld #другое имя'
# Включить/Отключить логин по паролю ("yes"/"no")
BS_SSH_PASSWORD_AUTHENTICATION="yes"
# Включить автоустановку обновлений безопасности ("true"/"false")
BS_AUTOUPDATE_ENABLED="true"
# Включить автоперезагрузку сервера, если это требуется после установки обновлений ("true"/"false")
BS_AUTOUPDATE_REBOOT_ENABLE="false"
# Указать время для автоперезагрузки
BS_AUTOUPDATE_REBOOT_TIME="05:00"
