#!/usr/bin/expect -f

set timeout 1800
match_max 100000
log_user 1
log_file -a "/tmp/endebx-menu-php-version.trace"

if {[info exists env(EXPECT_DEBUG)] && $env(EXPECT_DEBUG) eq "1"} {
    exp_internal 1
}

if {![info exists env(TEST_MENU_PHP_VERSION_TARGET)] || $env(TEST_MENU_PHP_VERSION_TARGET) eq ""} {
    puts stderr "TEST_MENU_PHP_VERSION_TARGET is not set"
    exit 1
}

proc fail_timeout {pattern} {
    puts stderr "Timeout waiting for: $pattern"
    exit 1
}

proc wait_for {pattern} {
    expect {
        -re $pattern {}
        timeout { fail_timeout $pattern }
        eof {
            puts stderr "Unexpected EOF while waiting for: $pattern"
            exit 1
        }
    }
}

proc send_line {value} {
    send -- "$value\r"
}

expect_before {
    -re {Action failed \(rc=([0-9]+)\)\. Check ansible output above\.} {
        puts stderr "Detected menu action failure with rc=$expect_out(1,string)"
        exit 1
    }
}

spawn env TERM=dumb /root/menu.sh

wait_for {Enter command: *}
send_line "4"

wait_for {Enter PHP version: \(example: 8\.2 or php8\.2\): *}
send_line $env(TEST_MENU_PHP_VERSION_TARGET)

wait_for {Set this version of php as the default version\?}
wait_for {\(Y/N\)\[[YN]\]: *}
send_line "Y"

wait_for {Do you really want to add PHP version\? \(Y/N\): *}
send_line "Y"

wait_for {To return to the menu, please press Enter}
send_line ""

wait_for {Enter command: *}
send_line "0"

expect eof
