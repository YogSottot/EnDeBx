#!/usr/bin/expect -f

set timeout 3600
match_max 100000
log_user 1

log_file -a "/tmp/endebx-menu-security-settings.trace"

if {[info exists env(EXPECT_DEBUG)] && $env(EXPECT_DEBUG) eq "1"} {
    exp_internal 1
}

proc fail_timeout {pattern} {
    puts stderr "Timeout waiting for: $pattern"
    exit 1
}

proc wait_for {pattern} {
    expect {
        -re $pattern {}
        timeout { fail_timeout $pattern }
        eof {
            puts stderr "Unexpected EOF while waiting for: $pattern"
            exit 1
        }
    }
}

proc send_line {value} {
    send -- "$value\r"
}

proc finish_menu_action {} {
    expect {
        -re {To return to the menu, please press Enter *} { send_line "" }
        -re {Press any key to return to the menu\.\.\. *} { send_line "" }
        -re {Press any key to continue\.\.\. *} { send_line "" }
        timeout { fail_timeout {menu action completion prompt} }
        eof {
            puts stderr "Unexpected EOF while waiting for menu action completion prompt"
            exit 1
        }
    }
}

spawn env TERM=dumb /root/menu.sh

expect_before {
    -re {Action failed \(rc=([0-9]+)\)\. Check ansible output above\.} {
        puts stderr "Detected menu action failure with rc=$expect_out(1,string)"
        exit 1
    }
}

wait_for {Enter command: *}
send_line "9"
wait_for {Enter command: *}
send_line "1"

wait_for {Enter SSH port \(default: [0-9]+\): *}
send_line $env(BS_SSH_PORT)

wait_for {Enter PermitRootLogin \(yes/no/prohibit-password\) \[[^\]]+\]: *}
send_line $env(BS_SSH_PERMIT_ROOT_LOGIN)

wait_for {Enter sudo admin user for SSH access \[[^\]]*\]: *}
if {[info exists env(BS_SSH_ADMIN_USER)]} {
    send_line $env(BS_SSH_ADMIN_USER)
} else {
    send_line ""
}

if {[info exists env(BS_SSH_ADMIN_USER)] && $env(BS_SSH_ADMIN_USER) ne ""} {
    wait_for {Use passwordless sudo for admin user \(true/false\) \[[^\]]+\]: *}
    send_line $env(BS_SSH_ADMIN_USER_PASSWORDLESS_SUDO)

    if {[info exists env(BS_SSH_ADMIN_USER_PASSWORDLESS_SUDO)] && $env(BS_SSH_ADMIN_USER_PASSWORDLESS_SUDO) eq "false"} {
        wait_for {Enter password for admin user \[[^\]]+\]: *}
        send_line $env(BS_SSH_ADMIN_USER_PASSWORD)
    }
}

wait_for {Enable PasswordAuthentication \(yes/no\) \[[^\]]+\]: *}
send_line $env(BS_SSH_PASSWORD_AUTHENTICATION)

wait_for {Enable unattended security updates \(true/false\) \[[^\]]+\]: *}
send_line $env(BS_AUTOUPDATE_ENABLED)

if {$env(BS_AUTOUPDATE_ENABLED) eq "true"} {
    wait_for {Enable auto reboot after updates \(true/false\) \[[^\]]+\]: *}
    send_line $env(BS_AUTOUPDATE_REBOOT_ENABLE)

    if {$env(BS_AUTOUPDATE_REBOOT_ENABLE) eq "true"} {
        wait_for {Enter auto reboot time in HH:MM \[[^\]]+\]: *}
        send_line $env(BS_AUTOUPDATE_REBOOT_TIME)
    }
}

wait_for {Enable hidepid for /proc \(true/false\) \[[^\]]+\]: *}
send_line $env(BS_SECRITY_HIDEPID)

if {$env(BS_SECRITY_HIDEPID) eq "true"} {
    wait_for {Enter existing monitoring user for /proc access \(optional\) \[[^\]]*\]: *}
    if {[info exists env(BS_SECRITY_HIDEPID_MONITORING_USER)]} {
        send_line $env(BS_SECRITY_HIDEPID_MONITORING_USER)
    } else {
        send_line ""
    }
}

wait_for {Do you really want to apply security settings\? \(Y/N\): *}
send_line "Y"

finish_menu_action
wait_for {Enter command: *}
send_line "0"
wait_for {Enter command: *}
send_line "0"

expect eof
