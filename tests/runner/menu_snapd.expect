#!/usr/bin/expect -f

set timeout 3600
match_max 100000
log_user 1

set action "install"
if {[info exists env(TEST_MENU_SNAPD_ACTION)] && $env(TEST_MENU_SNAPD_ACTION) ne ""} {
    set action [string tolower $env(TEST_MENU_SNAPD_ACTION)]
}

log_file -a "/tmp/endebx-menu-snapd-${action}.trace"

if {[info exists env(EXPECT_DEBUG)] && $env(EXPECT_DEBUG) eq "1"} {
    exp_internal 1
}

proc fail_timeout {pattern} {
    puts stderr "Timeout waiting for: $pattern"
    exit 1
}

proc wait_for {pattern} {
    expect {
        -re $pattern {}
        timeout { fail_timeout $pattern }
        eof {
            puts stderr "Unexpected EOF while waiting for: $pattern"
            exit 1
        }
    }
}

proc send_line {value} {
    send -- "$value\r"
}

proc open_snapd_menu {} {
    wait_for {Enter command: *}
    send_line "8"
    wait_for {Enter command: *}
    send_line "7"
}

proc finish_action {} {
    expect {
        -re {To return to the menu, please press Enter *} { send_line "" }
        -re {Press any key to return to the menu\.\.\. *} { send_line "" }
        -re {Press any key to continue\.\.\. *} { send_line "" }
        timeout { fail_timeout {menu return prompt} }
        eof {
            puts stderr "Unexpected EOF while waiting for menu return prompt"
            exit 1
        }
    }

    wait_for {Enter command: *}
    send_line "0"
    wait_for {Enter command: *}
    send_line "0"
}

spawn env TERM=dumb /root/menu.sh

expect_before {
    -re {Action failed \(rc=([0-9]+)\)\. Check ansible output above\.} {
        puts stderr "Detected menu action failure with rc=$expect_out(1,string)"
        exit 1
    }
}

open_snapd_menu
wait_for {Do you really want to.*Snapd\? \(Y/N\): *}
send_line "Y"
finish_action

expect eof
