#!/usr/bin/expect -f

set timeout 1800
match_max 100000
log_user 1

set action "create"
if {[info exists env(TEST_MENU_FTP_ACTION)] && $env(TEST_MENU_FTP_ACTION) ne ""} {
    set action [string tolower $env(TEST_MENU_FTP_ACTION)]
}

log_file -a "/tmp/endebx-menu-ftp-${action}.trace"

if {[info exists env(EXPECT_DEBUG)] && $env(EXPECT_DEBUG) eq "1"} {
    exp_internal 1
}

proc fail_timeout {pattern} {
    puts stderr "Timeout waiting for: $pattern"
    exit 1
}

proc wait_for {pattern} {
    expect {
        -re $pattern {}
        timeout { fail_timeout $pattern }
        eof {
            puts stderr "Unexpected EOF while waiting for: $pattern"
            exit 1
        }
    }
}

proc send_line {value} {
    send -- "$value\r"
}

spawn env TERM=dumb /root/menu.sh

expect_before {
    -re {Action failed \(rc=([0-9]+)\)\. Check ansible output above\.} {
        puts stderr "Detected menu action failure with rc=$expect_out(1,string)"
        exit 1
    }
}

wait_for {Enter command: *}
send_line "3"

wait_for {Do you want to Create or Delete FTP-user\? \(C/D\) \[[^\]]+\]: *}
if {$action eq "create"} {
    send_line "C"
    wait_for {Enter path to ftp directory \(default: .*}
    send_line $env(TEST_MENU_FTP_DIR)
    wait_for {Enter FTP username \[[^\]]+\]: *}
    send_line $env(TEST_MENU_FTP_USER)
    wait_for {Enter FTP user password \[[^\]]+\]: *}
    send_line $env(TEST_MENU_FTP_PASSWORD)
} elseif {$action eq "delete"} {
    send_line "D"
    wait_for {Enter the number of the user you want to delete \(or 0 to cancel\): *}
    send_line $env(TEST_MENU_FTP_DELETE_INDEX)
    wait_for {Are you sure you want to delete user '[^']+'\? \(y/N\): *}
    send_line "y"
} else {
    puts stderr "Unsupported TEST_MENU_FTP_ACTION: $action"
    exit 1
}

wait_for {Do you really want to [a-z]+ an FTP user\? \(Y/N\): *}
send_line "Y"
wait_for {Press any key to return to the menu\.\.\.}
send_line ""
wait_for {Enter command: *}
send_line "0"

expect eof
